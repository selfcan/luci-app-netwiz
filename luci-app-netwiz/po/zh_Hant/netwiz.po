msgid ""
msgstr "Content-Type: text/plain; charset=UTF-8\n"

msgid "Network Wizard"
msgstr "網路設定"

msgid "Netwiz NETWORK SETUP"
msgstr "Netwiz 網路設定精靈"

msgid "Pure · Secure · Non-destructive Minimalist Config"
msgstr "純粹 · 安全 · 無損的極簡設定"

msgid "Secondary Router Mode"
msgstr "二級路由模式"

msgid "Upstream network dials up, this device acts as a secondary router."
msgstr "上級網路負責撥號，本設備作為二級路由使用。"

msgid "PPPoE Dial-up"
msgstr "PPPoE 撥號"

msgid "Dial up directly using account and password on this device."
msgstr "在本設備上直接使用寬頻帳號和密碼進行撥號。"

msgid "LAN Settings"
msgstr "區域網路設定"

msgid "Change device LAN IP, or switch to AP Wired Relay mode."
msgstr "修改設備的區域網路 IP，或切換至旁路由（AP有線中繼）模式。"

msgid "Reading underlying config..."
msgstr "正在讀取底層設定..."

msgid "Back to Home"
msgstr "返回首頁"

msgid "Configure WAN"
msgstr "設定外網 (WAN)"

msgid "Connection Type"
msgstr "連線方式"

msgid "DHCP (Auto)"
msgstr "自動取得 IP (DHCP)"

msgid "Static IP"
msgstr "靜態 IP"

msgid "Gateway"
msgstr "閘道器"

msgid "e.g., 192.168.1.2"
msgstr "例如：192.168.1.2"

msgid "e.g., 192.168.1.1"
msgstr "例如：192.168.1.1"

msgid "PPPoE Credentials"
msgstr "PPPoE 撥號資訊"

msgid "PPPoE Username"
msgstr "寬頻帳號"

msgid "Enter PPPoE username"
msgstr "請輸入寬頻帳號"

msgid "PPPoE Password"
msgstr "寬頻密碼"

msgid "Enter PPPoE password"
msgstr "請輸入寬頻密碼"

msgid "Configure LAN"
msgstr "設定區域網路 (LAN)"

msgid "Safe Mode (Recommended ON)"
msgstr "安全模式 (建議開啟，防失聯)"

msgid "Enable AP Wired Relay"
msgstr "啟用旁路由（AP有線中繼）模式"

msgid "<b style=\"font-size: 16px;\">AP Wired Relay Enabled:</b><br>1. DHCP will be disabled. <b style=\"color: #059669;\">Devices must use static IPs or get IPs from upstream.</b><br>2. Gateway MUST be the upstream router IP.<br>3. If LAN IP changes, ensure your client is in the same subnet to avoid <b style=\"color: #059669;\">losing access</b>."
msgstr "<b style=\"font-size: 16px;\">旁路由（AP有線中繼）模式已啟用：</b><br>1. DHCP 服務將被停用，<b style=\"color: #059669;\">下級設備需手動指定 IP 或由上級路由分配。</b><br>2. 閘道器【必須】填寫為上級路由器的 IP。<br>3. 若修改了區域網路 IP，請確保您的設備也處於同網段，以免<b style=\"color: #059669;\">失去連線</b>。"

msgid "<b style=\"font-size: 16px;\">Main Router Mode Enabled:</b><br>1. DHCP will be enabled. This device assigns IPs.<br>2. Gateway is usually left blank.<br>3. If LAN IP changes, ensure your client is in the same subnet to avoid <b style=\"color: #dc2626;\">losing access</b>."
msgstr "<b style=\"font-size: 16px;\">主路由模式已啟用：</b><br>1. DHCP 服務已開啟，本設備將向下級分配 IP。<br>2. 作為主路由時，閘道器通常留空即可。<br>3. 若修改了區域網路 IP，請確保您的設備也處於同網段，以免<b style=\"color: #dc2626;\">失去連線</b>。"

msgid "Device LAN IP"
msgstr "設備區域網路 IP"

msgid "LAN Gateway"
msgstr "區域網路閘道器"

msgid "Blank for Main, required for AP Wired Relay"
msgstr "主路由留空，旁路由（AP有線中繼）必填"

msgid "Back"
msgstr "上一步"

msgid "Next Step"
msgstr "下一步"

msgid "Back to Edit"
msgstr "返回修改"

msgid "Confirm Configuration"
msgstr "確認設定資訊"

msgid "The following settings will be applied, please verify:"
msgstr "即將套用以下網路設定，請仔細核對："

msgid "Application Notes:"
msgstr "套用須知："

msgid "After confirmation, the network will restart and apply new settings."
msgstr "確認後，系統將重啟網路服務以套用新設定。"

msgid "The system will auto-refresh or redirect in 15 seconds."
msgstr "大約 15 秒後，頁面將自動重新整理或跳轉。"

msgid "Apply Settings"
msgstr "確認並套用"

msgid "AP Wired Relay"
msgstr "旁路由（AP有線中繼）模式"

msgid "Main Router (PPPoE)"
msgstr "主路由 (PPPoE 撥號)"

msgid "Secondary Router (DHCP)"
msgstr "二級路由 (自動取得)"

msgid "Secondary Router (Static IP)"
msgstr "二級路由 (靜態 IP)"

msgid "LAN Mode"
msgstr "區域網路模式"

msgid "Device IP:"
msgstr "設備 IP："

msgid "Upstream GW:"
msgstr "上級閘道器："

msgid "Public IP:"
msgstr "公網 IP："

msgid "Remote GW:"
msgstr "遠端閘道器："

msgid "LAN IP:"
msgstr "區域網路 IP："

msgid "Status:"
msgstr "狀態："

msgid "Waiting for remote response"
msgstr "等待遠端回應..."

msgid "WAN IP:"
msgstr "外網 IP："

msgid "Getting IP..."
msgstr "正在取得 IP..."

msgid "DHCP Service:"
msgstr "DHCP 服務："

msgid "Enabled"
msgstr "已開啟"

msgid "Disabled"
msgstr "已停用"

msgid "Dial Success"
msgstr "撥號成功"

msgid "Dialing / Disconnected"
msgstr "撥號中 / 未連線"

msgid "IP Acquired"
msgstr "已取得 IP"

msgid "Waiting for IP..."
msgstr "等待分配 IP..."

msgid "Interface Connected"
msgstr "介面已連線"

msgid "Cable Unplugged"
msgstr "網路線未插入"

msgid "Getting..."
msgstr "取得中..."

msgid "Not acquired"
msgstr "未取得"

msgid "Not set"
msgstr "未設定"

msgid "Incomplete info"
msgstr "資訊不完整"

msgid "Device IP cannot be empty."
msgstr "設備 IP 不能為空。"

msgid "Static IP and Gateway cannot be empty."
msgstr "靜態 IP 和閘道器不能為空。"

msgid "PPPoE username and password cannot be empty."
msgstr "寬頻帳號和密碼不能為空。"

msgid "Format Error"
msgstr "格式錯誤"

msgid "The device IP is invalid, please check!"
msgstr "設備 IP 格式不正確，請檢查！"

msgid "WAN IP is invalid, please check!"
msgstr "外網 IP 格式不正確，請檢查！"

msgid "Gateway IP is invalid, please check!"
msgstr "閘道器 IP 格式不正確，請檢查！"

msgid "Logic Error"
msgstr "邏輯錯誤"

msgid "AP Wired Relay requires an upstream gateway IP."
msgstr "旁路由（AP有線中繼）模式下，閘道器為必填項。"

msgid "WAN Static IP MUST NOT be the same as the gateway!"
msgstr "WAN 靜態 IP 絕對不能和閘道器一模一樣！"

msgid "The AP Wired Relay Device IP MUST NOT be the same as the Gateway!"
msgstr "旁路由（AP有線中繼）的設備 IP 絕對不能和上級閘道器一模一樣！"

msgid "No Changes Needed"
msgstr "未發生更改"

msgid "Your settings match the current router config exactly."
msgstr "您的設定與底層設定完全一致，無需重複下發。"

msgid "Exit to Home"
msgstr "返回首頁"

msgid "Conflict Blocked"
msgstr "設定衝突攔截"

msgid "The WAN IP cannot be the same as the current LAN IP ({ip})!"
msgstr "WAN 埠 IP 不能與目前區域網路 IP ({ip}) 相同！"

msgid "The WAN port cannot be in the same subnet as the LAN ({ip})!"
msgstr "WAN 埠不能與區域網路 ({ip}) 處於同一網段！"

msgid "This causes a routing loop."
msgstr "這會導致嚴重的路由迴圈。"

msgid "Suggestion: Your upstream network uses the same IP subnet. Please go to [LAN Settings] first and change your Device LAN IP (e.g. to 192.168.10.1) to prevent network crash."
msgstr "建議：您的上級網路使用了相同的 IP 網段。請先前往【區域網路設定】，修改本設備的區域網路 IP（例如改為 192.168.10.1）以防止網路癱瘓。"

msgid "Subnet Error"
msgstr "網段錯誤"

msgid "The WAN Static IP must be in the same subnet as the Gateway!"
msgstr "WAN 靜態 IP 必須與閘道器處於同一網段！"

msgid "e.g., if gateway is {gw}, the IP must be {ip}.x"
msgstr "例如：如果閘道器是 {gw}，則 IP 必須是 {ip}.x"

msgid "The AP Wired Relay Device IP must be in the same subnet as the Gateway!"
msgstr "旁路由（AP有線中繼）的設備 IP 必須與上級閘道器處於同一網段！"

msgid "Config Warning"
msgstr "高危操作警告"

msgid "You selected [Main Router Mode] but filled in the [Gateway].<br><br><b>For a standard main router, the gateway must be blank.</b> Entering a gateway may cause the device to fail at distributing network, leading to a total outage!<br><br>Are you sure you want to do this?"
msgstr "您選擇了【主路由模式】，但填寫了【閘道器】。<br><br><b>作為主路由，閘道器必須留空。</b>強行指定閘道器極易導致底層路由表錯亂，全屋斷網！<br><br>您確定要繼續強行保存嗎？"

msgid "Force Apply"
msgstr "確認強行保存"

msgid "System Exception"
msgstr "系統異常"

msgid "Cannot read underlying config for validation, please refresh."
msgstr "無法讀取底層設定進行防呆校驗，請重新整理頁面重試。"

msgid "Applying Configuration"
msgstr "正在套用設定"

msgid "Close"
msgstr "關閉"

msgid "Account"
msgstr "帳號"

msgid "Password"
msgstr "密碼"

msgid "IP & Gateway"
msgstr "IP 與閘道器"

msgid "Auto-assigned by upstream router"
msgstr "由上級路由自動分配"

msgid "Target:"
msgstr "目標："

msgid "Modifying LAN IP"
msgstr "正在修改區域網路 IP"

msgid "Switching to AP Wired Relay"
msgstr "正在切換至旁路由（AP有線中繼）模式"

msgid "Switching WAN to DHCP"
msgstr "正在切換 WAN 埠為 DHCP (自動取得)"

msgid "Switching WAN to Static IP"
msgstr "正在切換 WAN 埠為靜態 IP"

msgid "Applying PPPoE Dial-up"
msgstr "正在套用 PPPoE 撥號"

msgid "Writing configuration to system, please do not close the page..."
msgstr "正在將設定寫入系統，請勿關閉頁面..."

msgid "Connecting to new IP... Config will auto-rollback upon timeout."
msgstr "正在嘗試連接新 IP... 失聯超時將會自動回滾配置"

msgid "Waiting for network service to restart... Elapsed: {sec}s"
msgstr "正在等待網路服務重啟... 已耗時：{sec}秒"

msgid "Waiting for router to safely restore... Elapsed: {sec}s"
msgstr "正在等待舊 IP 恢復... 已耗時：{sec}秒"

msgid "Rollback countdown: <b style=\"color:#f59e0b;\">{sec}</b> / {total} s"
msgstr "防失聯倒數計時：<b style=\"color:#f59e0b;\">{sec}</b> / {total} 秒"

msgid "If enabled, the system will auto-revert if you lose connection within 120s."
msgstr "開啟後，若修改 IP 導致失聯，系統將在 120 秒後自動回退恢復。"

msgid "Safe mode disabled. Applying immediately without rollback protection..."
msgstr "已關閉防失聯保護，配置立刻生效。"

msgid "If IP changed, please update PC IP. Auto-redirecting when connected..."
msgstr "若 IP 修改引發失聯，將設備 IP 改為同網段即可正常存取路由器，網路連通後將自動跳轉…"

msgid "Waiting for router to abort changes and restore network..."
msgstr "正在等待路由器放棄修改並恢復網絡..."

msgid "Wi-Fi Settings"
msgstr "Wi-Fi 設定"

msgid "Configure wireless network, SSID, and password."
msgstr "設定無線網路名稱、密碼及加密方式。"

msgid "Configure Wi-Fi"
msgstr "設定 Wi-Fi"

msgid "Smart Connect (All Bands)"
msgstr "多頻合一 (智能漫遊)"

msgid "Enable Wi-Fi"
msgstr "啟用 Wi-Fi"

msgid "Enable 2.4G Wi-Fi"
msgstr "啟用 2.4G Wi-Fi"

msgid "Enable 5G Wi-Fi"
msgstr "啟用 5G/雙路 Wi-Fi"

msgid "Network Name (SSID)"
msgstr "無線網路名稱 (SSID)"

msgid "Wi-Fi Password"
msgstr "Wi-Fi 密碼"

msgid "Encryption"
msgstr "加密方式"

msgid "Enable 802.11b (Legacy Mode)"
msgstr "啟用 802.11b (舊版相容模式)"

msgid "Only enable if very old IoT devices cannot connect."
msgstr "僅在極舊的智慧家電/物聯網設備無法連線時才建議開啟。"

msgid "No Password (Open)"
msgstr "無密碼 (開放)"

msgid "WPA2-PSK (Stable)"
msgstr "WPA2-PSK (穩定相容)"

msgid "WPA3-SAE (Secure)"
msgstr "WPA3-SAE (高安全性)"

msgid "WPA2/WPA3 Mixed (Recommended)"
msgstr "WPA2/WPA3 混合 (建議)"

msgid "2.4G Wi-Fi"
msgstr "2.4G Wi-Fi"

msgid "5G Wi-Fi"
msgstr "5G/雙路 Wi-Fi"

msgid "SSID cannot be empty."
msgstr "網路名稱 (SSID) 不能為空。"

msgid "Wi-Fi password must be at least 8 characters."
msgstr "Wi-Fi 密碼長度必須至少為 8 個字元。"

msgid "Applying Wi-Fi Settings"
msgstr "正在套用 Wi-Fi 設定"

msgid "Advanced Settings"
msgstr "進階設定"

msgid "Hide Advanced"
msgstr "收起進階設定"

msgid "Hide Wi-Fi Name (SSID)"
msgstr "隱藏 Wi-Fi 名稱"

msgid "Channel"
msgstr "頻道 (Channel)"

msgid "Channel Width"
msgstr "通道寬度 (頻寬)"

msgid "Auto"
msgstr "自動"

msgid "Wireless Mode"
msgstr "無線模式 (Mode)"

msgid "⚠️ Severe Warning"
msgstr "⚠️ 嚴重警告"

msgid "Forcibly modifying the wireless physical mode may cause the hardware driver to crash or the Wi-Fi to disappear permanently if the chip does not support it! It is highly recommended to keep it on [Auto].<br><br>Are you absolutely sure you want to change this?"
msgstr "如果強行指定的物理模式與網卡晶片實際支援的能力不匹配，將導致<b>底層驅動直接崩潰、Wi-Fi 永久消失！</b>強烈建議保持為【自動 (推薦)】。<br><br>您確定要強行修改模式嗎？"

msgid "Enable IPv6 (DHCPv6)"
msgstr "啟用 IPv6 (DHCPv6)"

msgid "Wi-Fi Status"
msgstr "Wi-Fi 狀態"

msgid "5G Wi-Fi Account"
msgstr "5G/雙路 Wi-Fi 帳號"

msgid "2.4G Wi-Fi Account"
msgstr "2.4G Wi-Fi 帳號"

msgid "No Password"
msgstr "無密碼"

msgid "Enable Wireless Relay (WISP)"
msgstr "啟用無線中繼 (WISP)"

msgid "Receive upstream Wi-Fi and broadcast your own network."
msgstr "接收上級 Wi-Fi 信號，並廣播您自己的專屬網絡。"

msgid "WISP Enabled"
msgstr "已開啟無線中繼"

msgid "Scan Nearby Wi-Fi"
msgstr "掃描附近 Wi-Fi"

msgid "Select Upstream Network"
msgstr "選擇上級網絡"

msgid "Password for upstream:"
msgstr "上級 Wi-Fi 密碼："

msgid "Scanning..."
msgstr "正在掃描..."

msgid "No networks found."
msgstr "未找到任何網絡。"

msgid "Scan failed. Driver might be busy."
msgstr "掃描失敗。無線驅動可能繁忙，請重試。"

msgid "Target Wi-Fi"
msgstr "目標 Wi-Fi 名稱"

msgid "Upstream Wi-Fi Password"
msgstr "請輸入上級 Wi-Fi 的密碼"

msgid "802.11k/v/r Fast Roaming"
msgstr "802.11k/v/r 無縫漫遊"

msgid "Enable seamless roaming between routers with one click (Prerequisite: Same SSID, password, and LAN). Note: May cause connection issues with older smart home (IoT) devices."
msgstr "一鍵開啟路由器間的無縫切換（基本前提：帳號、密碼一樣 + 同一區域網路）。注意：可能導致老舊的智慧家庭（IoT）設備無法連線。"

msgid "⚠️ Manual Configuration Warning"
msgstr "⚠️ 手動設定警告"

msgid "Underlying parameter mismatch detected, which may cause roaming failures. Please toggle this switch off and on again, then save to apply the standard seamless roaming profile."
msgstr "檢測到底層參數與預設不一致，可能會導致漫遊失敗。建議將開關關閉後重新開啟，儲存後即可加入多設備全空間「絲滑」跳轉的「朋友圈」。"

msgid "Roaming"
msgstr "漫遊"

msgid "Roaming Enabled"
msgstr "已開通漫遊"

msgid "Click to Fix"
msgstr "點擊修復"

msgid "Click to Settings"
msgstr "點擊直達設定"

msgstr "批量解绑设备"

msgid "Among the {total} selected devices, <b>{valid}</b> have fixed IPs.<br><br>Are you sure you want to unbind them?"
msgstr "选中的 {total} 台设备中，有 <b>{valid}</b> 台当前已固定 IP。<br><br>确定要解除它们的绑定吗？"

msgid "Batch releasing IPs, please wait..."
msgstr "正在批量释放 IP，请稍候..."

msgid "Batch Assign Settings"
msgstr "批量分配设置"

msgid "Select Assign Strategy <span style=\"font-weight:normal; font-size:13.5px; color:#64748b;\">(Selected <b style=\"color:#3b82f6;\">{count}</b> devices)</span>"
msgstr "选择分配策略 <span style=\"font-weight:normal; font-size:13.5px; color:#64748b;\">(已选中 <b style=\"color:#3b82f6;\">{count}</b> 台设备)</span>"

msgid "Start Assign"
msgstr "开始分配"

msgid "Avoiding conflicts and silently writing rules..."
msgstr "正在雷达避冲突并静默写入规则..."

msgid "No device records found in current LAN"
msgstr "当前局域网内未发现任何设备记录"

msgid "❌ Scan failed: Cannot retrieve underlying data"
msgstr "❌ 扫描失败：无法获取底层数据"

msgid "❌ The IP pool for this type is full. Please expand the range or choose another strategy!"
msgstr "❌ 该类型的 IP 分段池已全部被占满，请扩大范围或选择其它策略！"

msgid "IP address cannot be empty!"
msgstr "IP 地址不能为空！"

msgid "❌ IP Conflict Blocked!\n\nThe IP [{ip}] is occupied by device [{name}].\nPlease modify the strategy or enter a free IP!"
msgstr "❌ IP 冲突拦截！\n\n您输入的 IP [{ip}] 已被局域网中的设备【{name}】占用。\n请修改策略或输入一个未被占用的空闲 IP！"

msgid "💡 Tip: The device is already fixed at this IP. No changes needed!"
msgstr "💡 提示：该设备已经是当前 IP 且已固定，配置未发生任何改变，无需重复提交！"

msgid "💡 Tip: The {count} selected devices are all [Unbound]. No unbind action needed!"
msgstr "💡 提示：您选中的 {count} 台设备目前全是【未绑定】状态，无需执行解绑操作！"

msgid "Starting suffix must be between 2 and 254!"
msgstr "起始后缀必须在 2 到 254 之间！"

msgid "❌ IP pool insufficient!\nOnly {avail} IPs left from .{suf}, but {count} devices selected."
msgstr "❌ IP 池容量不足！\n从 .{suf} 开始顺延仅剩 {avail} 个可用 IP，但您选中了 {count} 台设备。"

msgid "❌ [{name}] assignment failed!\nSelected {req} devices, but only {avail} IPs available in the preset range.\nPlease expand the IP range for this category!"
msgstr "❌ 【{name}】分配失败！\n选中了 {req} 台设备，但预设的 IP 段内只有 {avail} 个可用 IP。\n请扩大该类别的 IP 段范围！"

msgid "💡 Smart block: According to your strategy, the {count} selected devices are already fixed with unchanged IPs. No need to rewrite rules!"
msgstr "💡 智能拦截：根据您的策略计算，选中的 {count} 台设备【均已固定且 IP 未改变】，无需重复下发规则！"

msgid "Infinite"
msgstr "永久"

msgid "Expired"
msgstr "已过期"

msgid "Terminal Device & IP Binding"
msgstr "终端设备与 IP 绑定"

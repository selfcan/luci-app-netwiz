START=99
USE_PROCD=1
LOG_FILE="/tmp/netwiz.log"

log() {
    echo "$(date '+%F %T') [Service] $1" >> "$LOG_FILE"
    if [ $(wc -l < "$LOG_FILE" 2>/dev/null || echo 0) -gt 600 ]; then
        tail -n 500 "$LOG_FILE" > "$LOG_FILE.tmp"
        mv "$LOG_FILE.tmp" "$LOG_FILE"
    fi
}

start_service() {
    log "========== Netwiz 服务启动 =========="
    
    # 🌟 1. 动态获取系统真实的中文包后缀 (完美兼容 zh-cn 或 zh_cn)
    REAL_LANG=$(ls /www/luci-static/resources/i18n/base.*.json 2>/dev/null | awk -F'.' '{print $2}' | grep -i "zh" | head -n 1)
    [ -z "$REAL_LANG" ] && REAL_LANG=$(ls /usr/lib/lua/luci/i18n/base.*.lmo 2>/dev/null | awk -F'.' '{print $2}' | grep -i "zh" | head -n 1)
    [ -z "$REAL_LANG" ] && REAL_LANG="zh-cn"
    
    # 2. 彻底锁定底层语言，并重启 Web 服务清空内存
    local is_lang_init=$(uci -q get netwiz.global.lang_init)
    if [ "$is_lang_init" != "1" ]; then
        uci -q set luci.main.lang="$REAL_LANG"
        uci commit luci
        rm -rf /tmp/luci-indexcache /tmp/luci-modulecache/* 2>/dev/null
        log "已清理 LuCI 缓存，强锁语言为 [$REAL_LANG]，正在后台重启 Web 服务..."
        
        /etc/init.d/rpcd restart 2>/dev/null
        /etc/init.d/uhttpd restart 2>/dev/null
        
        uci -q set netwiz.global.lang_init='1'
        uci commit netwiz
    fi
    
    local configured=$(uci -q get netwiz.global.configured)
    local pwd_hash=$(awk -F: '/^root:/ {print $2}' /etc/shadow)
    local is_empty_pwd=0
    if [ -z "$pwd_hash" ] || [ "$pwd_hash" = "!" ] || [ "$pwd_hash" = "*" ] || [ "$pwd_hash" = "x" ]; then
        is_empty_pwd=1
    fi

    local is_in_rom=0
    if [ -f /rom/etc/init.d/netwiz-monitor ]; then
        is_in_rom=1
    fi
    
    if [ "$configured" != "1" ]; then
        if [ "$is_empty_pwd" -eq 1 ] || [ "$is_in_rom" -eq 1 ]; then
            log "触发初次向导配置，生成拦截 CGI 脚本"
            
            [ -f /www/cgi-bin/luci.bak ] || cp -p /www/cgi-bin/luci /www/cgi-bin/luci.bak
            
            if [ "$is_empty_pwd" -eq 1 ]; then
                # 🌟 免密登录版本：最纯正的 Form 同步提交，附带精准语言包
                cat << 'EOF' > /www/cgi-bin/luci
#!/bin/sh
CONF=$(uci -q get netwiz.global.configured)

if [ "$CONF" != "1" ]; then
    case "$PATH_INFO" in
        *rescue*)
            uci -q set netwiz.global.configured='1'
            uci commit netwiz
            [ -f /www/cgi-bin/luci.bak ] && mv -f /www/cgi-bin/luci.bak /www/cgi-bin/luci
            printf "Status: 302 Found\r\n"
            printf "Location: /cgi-bin/luci/\r\n\r\n"
            exit 0
            ;;
        *admin/netwiz*|*luci-static*|*rpc*)
            ;;
        *)
            # 在 CGI 运行时动态抓取真实语言后缀
            REAL_LANG=$(ls /www/luci-static/resources/i18n/base.*.json 2>/dev/null | awk -F'.' '{print $2}' | grep -i "zh" | head -n 1)
            [ -z "$REAL_LANG" ] && REAL_LANG=$(ls /usr/lib/lua/luci/i18n/base.*.lmo 2>/dev/null | awk -F'.' '{print $2}' | grep -i "zh" | head -n 1)
            [ -z "$REAL_LANG" ] && REAL_LANG="zh-cn"

            printf "Status: 200 OK\r\n"
            printf "Content-Type: text/html; charset=utf-8\r\n"
            printf "Cache-Control: no-store, no-cache, must-revalidate, max-age=0\r\n\r\n"
            printf "<!DOCTYPE html><html><body style='background:#f8fafc;'>"
            printf "<div style='text-align:center; margin-top:20vh; font-family:sans-serif; color:#64748b;'>"
            printf "<div style='width: 30px; height: 30px; border: 3px solid #cbd5e1; border-top-color: #3b82f6; border-radius: 50%%; animation: spin 1s linear infinite; margin: 0 auto 15px;'></div>"
            printf "<style>@keyframes spin { 0%% { transform: rotate(0deg); } 100%% { transform: rotate(360deg); } }</style>"
            printf "正在初始化系统...</div>"
            
            # 🚨 终极杀招：把抓取到的精准语言代码，名正言顺地在 POST 表单里提交给系统
            printf "<form id='al' action='/cgi-bin/luci/admin/netwiz' method='post'>"
            printf "<input type='hidden' name='luci_username' value='root'>"
            printf "<input type='hidden' name='luci_password' value=''>"
            printf "<input type='hidden' name='luci_lang' value='%s'>" "$REAL_LANG"
            printf "</form>"
            printf "<script>\n"
            printf "document.cookie = 'luci_lang=%s; path=/; max-age=86400';\n" "$REAL_LANG"
            printf "setTimeout(function(){ document.getElementById('al').submit(); }, 100);\n"
            printf "</script></body></html>\n"
            exit 0
            ;;
    esac
fi

exec /www/cgi-bin/luci.bak
EOF
            else
                # 🌟 有密码版本：写入精确 Cookie 后跳转
                cat << 'EOF' > /www/cgi-bin/luci
#!/bin/sh
CONF=$(uci -q get netwiz.global.configured)

if [ "$CONF" != "1" ]; then
    case "$PATH_INFO" in
        *rescue*)
            uci -q set netwiz.global.configured='1'
            uci commit netwiz
            [ -f /www/cgi-bin/luci.bak ] && mv -f /www/cgi-bin/luci.bak /www/cgi-bin/luci
            printf "Status: 302 Found\r\n"
            printf "Location: /cgi-bin/luci/\r\n\r\n"
            exit 0
            ;;
        *admin/netwiz*|*luci-static*|*rpc*)
            ;;
        *)
            REAL_LANG=$(ls /www/luci-static/resources/i18n/base.*.json 2>/dev/null | awk -F'.' '{print $2}' | grep -i "zh" | head -n 1)
            [ -z "$REAL_LANG" ] && REAL_LANG=$(ls /usr/lib/lua/luci/i18n/base.*.lmo 2>/dev/null | awk -F'.' '{print $2}' | grep -i "zh" | head -n 1)
            [ -z "$REAL_LANG" ] && REAL_LANG="zh-cn"

            printf "Status: 200 OK\r\n"
            printf "Content-Type: text/html; charset=utf-8\r\n"
            printf "Cache-Control: no-store, no-cache, must-revalidate, max-age=0\r\n\r\n"
            printf "<!DOCTYPE html><html><body>"
            printf "<script>\n"
            printf "document.cookie = 'luci_lang=%s; path=/; max-age=86400';\n" "$REAL_LANG"
            printf "window.location.replace('/cgi-bin/luci/admin/netwiz');\n"
            printf "</script></body></html>\n"
            exit 0
            ;;
    esac
fi

exec /www/cgi-bin/luci.bak
EOF
            fi
            
            chmod +x /www/cgi-bin/luci
        else
            log "检测到已有密码且为后期安装，取消向导"
            uci -q set netwiz.global.configured='1'
            uci commit netwiz
            if [ -f /www/cgi-bin/luci.bak ]; then
                mv /www/cgi-bin/luci.bak /www/cgi-bin/luci
            fi
        fi
    else
        if [ -f /www/cgi-bin/luci.bak ]; then
            mv /www/cgi-bin/luci.bak /www/cgi-bin/luci
        fi
    fi

    procd_open_instance
    procd_set_param command /usr/libexec/netwiz-monitor-loop.sh
    procd_set_param respawn
    procd_close_instance
}

service_triggers() {
    procd_add_reload_trigger "netwiz"
}

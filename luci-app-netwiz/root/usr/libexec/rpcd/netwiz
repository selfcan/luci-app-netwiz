#!/bin/sh

case "$1" in
    list)
        echo '{ "set_network": { "mode": "string", "arg1": "string", "arg2": "string", "arg3": "string", "arg4": "string" }, "do_update": {} }'
        exit 0
        ;;
    call)
        case "$2" in
            set_network)
                input=$(cat)
                mode=$(echo "$input" | jsonfilter -e '@.mode')
                arg1=$(echo "$input" | jsonfilter -e '@.arg1')
                arg2=$(echo "$input" | jsonfilter -e '@.arg2')
                arg3=$(echo "$input" | jsonfilter -e '@.arg3')
                arg4=$(echo "$input" | jsonfilter -e '@.arg4')

                # -------------------------------------------------------------
                # 💡 魔法拦截：如果发现 mode 是更新指令，直接拦截执行热更新！
                # -------------------------------------------------------------
                if [ "$mode" = "prepare_update" ]; then
                    echo '{"result":0}'
                    rm -f /tmp/netwiz_update.*
                    cat << 'EOF' > /tmp/nw_dl.sh
#!/bin/sh
if command -v apk >/dev/null 2>&1; then PKG="apk"; else PKG="ipk"; fi
URL="https://github.com/huchd0/luci-app-netwiz/releases/latest/download/luci-app-netwiz.${PKG}"

# 💡 终极修复：使用原生 Shell 循环代替不支持的 --tries=3，兼容所有 OpenWrt
for i in 1 2 3; do
    wget -qO "/tmp/netwiz_update.${PKG}" --no-check-certificate --timeout=15 "$URL"
    
    # 如果下载成功且文件有内容，打上 ready 标记并跳出循环
    if [ "$?" -eq 0 ] && [ -s "/tmp/netwiz_update.${PKG}" ]; then
        touch /tmp/netwiz_update.ready
        break
    fi
    # 如果失败，等 2 秒再重试
    sleep 2
done

# 3 次都失败了，清理残余坏文件
if [ ! -f /tmp/netwiz_update.ready ]; then
    rm -f "/tmp/netwiz_update.${PKG}"
fi
rm -f /tmp/nw_dl.sh
EOF
                    chmod +x /tmp/nw_dl.sh
                    /tmp/nw_dl.sh </dev/null >/dev/null 2>&1 &
                    exit 0
                    
                elif [ "$mode" = "check_update" ]; then
                    if [ -f /tmp/netwiz_update.ready ]; then
                        echo '{"result":1}'
                    else
                        echo '{"result":0}'
                    fi
                    exit 0
                    
                elif [ "$mode" = "do_install" ]; then
                    echo '{"result":0}'
                    cat << 'EOF' > /tmp/nw_install.sh
#!/bin/sh
sleep 2
if command -v apk >/dev/null 2>&1; then
    apk add --allow-untrusted --force-overwrite /tmp/netwiz_update.apk
else
    opkg install /tmp/netwiz_update.ipk --force-reinstall --force-overwrite
fi
rm -f /tmp/luci-indexcache /tmp/luci-modulecache/* /tmp/luci-app-netwiz.*
rm -f /tmp/netwiz_update.ready /tmp/netwiz_update.* /tmp/nw_install.sh
EOF
                    chmod +x /tmp/nw_install.sh
                    /tmp/nw_install.sh </dev/null >/dev/null 2>&1 &
                    exit 0
                fi

                # 正常的网络设置逻辑
                cleanup_lan_for_wan_modes() {
                    uci delete network.lan.gateway 2>/dev/null
                    uci delete network.lan.dns 2>/dev/null
                    uci set dhcp.lan.ignore='0'
                }

                if [ "$mode" = "wan_dhcp" ]; then
                    cleanup_lan_for_wan_modes
                    uci set network.wan.proto='dhcp'
                    uci commit network
                    uci commit dhcp
                    
                elif [ "$mode" = "wan_static" ]; then
                    cleanup_lan_for_wan_modes
                    uci set network.wan.proto='static'
                    uci set network.wan.ipaddr="$arg1"
                    uci set network.wan.gateway="$arg2"
                    uci set network.wan.netmask="$arg3"
                    uci commit network
                    uci commit dhcp
                    
                elif [ "$mode" = "pppoe" ]; then
                    cleanup_lan_for_wan_modes
                    uci set network.wan.proto='pppoe'
                    uci set network.wan.username="$arg1"
                    uci set network.wan.password="$arg2"
                    uci commit network
                    uci commit dhcp
                    
                elif [ "$mode" = "lan" ]; then
                    uci set network.lan.proto='static'
                    uci set network.lan.ipaddr="$arg1"
                    uci set network.lan.netmask="$arg3"
                    
                    if [ -n "$arg2" ]; then
                        uci set network.lan.gateway="$arg2"
                    else
                        uci delete network.lan.gateway 2>/dev/null
                    fi
                    
                    if [ "$arg4" = "1" ]; then
                        uci set dhcp.lan.ignore='1'
                        [ -n "$arg2" ] && uci set network.lan.dns="$arg2"
                    else
                        uci set dhcp.lan.ignore='0'
                        uci delete network.lan.dns 2>/dev/null
                    fi
                    
                    uci commit network
                    uci commit dhcp
                fi
                
                echo '{"result":0}'
                ( sleep 3; /etc/init.d/network restart; /etc/init.d/dnsmasq restart ) >/dev/null 2>&1 &
                exit 0
                ;;
            
            do_update)
                # 保留空壳，防止有遗留的旧代码调用报错
                echo '{"result":0}'
                exit 0
                ;;
        esac
        ;;
esac
exit 1

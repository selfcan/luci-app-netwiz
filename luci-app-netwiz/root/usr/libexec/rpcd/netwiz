#!/bin/sh
# 注册的 ubus 对象名称即为文件名 netwiz

case "$1" in
    list)
        # 声明可用方法及参数类型
        echo '{ "set_network": { "mode": "string", "arg1": "string", "arg2": "string" } }'
        exit 0
        ;;
    call)
        case "$2" in
            set_network)
                read input
                MODE=$(echo "$input" | jsonfilter -e '@.mode')
                ARG1=$(echo "$input" | jsonfilter -e '@.arg1')
                ARG2=$(echo "$input" | jsonfilter -e '@.arg2')

                if [ "$MODE" = "dhcp" ]; then
                    uci set network.wan.proto='dhcp'
                    uci delete network.wan.username >/dev/null 2>&1
                    uci delete network.wan.password >/dev/null 2>&1
                    uci commit network
                    ifdown wan && ifup wan

                elif [ "$MODE" = "pppoe" ]; then
                    uci set network.wan.proto='pppoe'
                    uci set network.wan.username="$ARG1"
                    uci set network.wan.password="$ARG2"
                    uci commit network
                    ifdown wan && ifup wan

                elif [ "$MODE" = "bypass" ]; then
                    uci set network.lan.ipaddr="$ARG1"
                    uci set network.lan.gateway="$ARG2"
                    uci delete network.lan.dns >/dev/null 2>&1
                    uci add_list network.lan.dns="$ARG2"
                    uci set dhcp.lan.ignore='1'
                    uci commit network
                    uci commit dhcp
                    /etc/init.d/network restart
                    /etc/init.d/dnsmasq restart
                fi

                # 返回成功状态
                echo '{ "result": 0 }'
                exit 0
                ;;
        esac
        ;;
esac
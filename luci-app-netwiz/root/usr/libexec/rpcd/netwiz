#!/bin/sh

case "$1" in
    list)
        echo '{ "set_network": { "mode": "string", "arg1": "string", "arg2": "string", "arg3": "string", "arg4": "string" }, "do_update": {} }'
        exit 0
        ;;
    call)
        case "$2" in
            set_network)
                input=$(cat)
                mode=$(echo "$input" | jsonfilter -e '@.mode')
                arg1=$(echo "$input" | jsonfilter -e '@.arg1')
                arg2=$(echo "$input" | jsonfilter -e '@.arg2')
                arg3=$(echo "$input" | jsonfilter -e '@.arg3')
                arg4=$(echo "$input" | jsonfilter -e '@.arg4')

                cleanup_lan_for_wan_modes() {
                    uci delete network.lan.gateway 2>/dev/null
                    uci delete network.lan.dns 2>/dev/null
                    uci set dhcp.lan.ignore='0'
                }

                if [ "$mode" = "wan_dhcp" ]; then
                    cleanup_lan_for_wan_modes
                    uci set network.wan.proto='dhcp'
                    uci commit network
                    uci commit dhcp
                elif [ "$mode" = "wan_static" ]; then
                    cleanup_lan_for_wan_modes
                    uci set network.wan.proto='static'
                    uci set network.wan.ipaddr="$arg1"
                    uci set network.wan.gateway="$arg2"
                    uci set network.wan.netmask="$arg3"
                    uci commit network
                    uci commit dhcp
                elif [ "$mode" = "pppoe" ]; then
                    cleanup_lan_for_wan_modes
                    uci set network.wan.proto='pppoe'
                    uci set network.wan.username="$arg1"
                    uci set network.wan.password="$arg2"
                    uci commit network
                    uci commit dhcp
                elif [ "$mode" = "lan" ]; then
                    uci set network.lan.proto='static'
                    uci set network.lan.ipaddr="$arg1"
                    uci set network.lan.netmask="$arg3"
                    if [ -n "$arg2" ]; then
                        uci set network.lan.gateway="$arg2"
                    else
                        uci delete network.lan.gateway 2>/dev/null
                    fi
                    
                    if [ "$arg4" = "1" ]; then
                        uci set dhcp.lan.ignore='1'
                        [ -n "$arg2" ] && uci set network.lan.dns="$arg2"
                    else
                        uci set dhcp.lan.ignore='0'
                        uci delete network.lan.dns 2>/dev/null
                    fi
                    uci commit network
                    uci commit dhcp
                fi
                
                echo '{"result":0}'
                ( sleep 3; /etc/init.d/network restart; /etc/init.d/dnsmasq restart ) >/dev/null 2>&1 &
                exit 0
                ;;
            
            do_update)
                echo '{"result":0}'
                # 💡 稳如泰山的更新机制：写入临时脚本并完全脱离父进程
                cat << 'EOF' > /tmp/nw_do_update.sh
#!/bin/sh
sleep 3
# 💡 修复 1：使用 ghproxy 加速，解决国内 GitHub Raw 无法访问导致 wget 死锁的问题
wget -qO- --no-check-certificate https://ghproxy.net/https://raw.githubusercontent.com/huchd0/luci-app-netwiz/master/install.sh | sh
rm -f /tmp/nw_do_update.sh
EOF
                chmod +x /tmp/nw_do_update.sh
                # 💡 修复 2：加入 </dev/null 彻底切断输入流，防止 rpcd 挂起等待！
                /tmp/nw_do_update.sh </dev/null >/tmp/nw_update_debug.log 2>&1 &
                exit 0
                ;;
        esac
        ;;
esac
exit 1

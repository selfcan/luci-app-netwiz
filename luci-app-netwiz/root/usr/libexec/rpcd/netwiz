LOG_FILE="/etc/netwiz.log"

log() {
    echo "$(date '+%F %T') [RPC] $1" >> "$LOG_FILE"
    # 防止恶意狂点前端按钮刷爆日志
    if [ $(wc -l < "$LOG_FILE" 2>/dev/null || echo 0) -gt 600 ]; then
        tail -n 500 "$LOG_FILE" > "$LOG_FILE.tmp"
        mv "$LOG_FILE.tmp" "$LOG_FILE"
    fi
}

case "$1" in
    list)
        # arg5 用于接收前端的安全开关状态
        echo '{ "set_network": { "mode": "string", "arg1": "string", "arg2": "string", "arg3": "string", "arg4": "string", "arg5": "string" }, "confirm": {} }'
        exit 0
        ;;
    call)
        case "$2" in
            confirm)
                if [ -f /tmp/netwiz_rollback_time ] || [ -f /tmp/netwiz_target_ip ]; then
                    # 确保四个文件被彻底删除干净，彻底解除定时装置
                    rm -f /tmp/netwiz_rollback_time /tmp/netwiz_target_ip /etc/config/network.netwiz_bak /etc/config/dhcp.netwiz_bak
                    log "成功：前端主动下发确认指令，已手动拆除回退定时装置"
                fi
                echo '{"result":0}'
                exit 0
                ;;
            set_network)
                input=$(cat)
                mode=$(echo "$input" | jsonfilter -e '@.mode')
                arg1=$(echo "$input" | jsonfilter -e '@.arg1')
                arg2=$(echo "$input" | jsonfilter -e '@.arg2')
                arg3=$(echo "$input" | jsonfilter -e '@.arg3')
                arg4=$(echo "$input" | jsonfilter -e '@.arg4')
                arg5=$(echo "$input" | jsonfilter -e '@.arg5') # 接收 arg5

                validate_ip_format() {
                    if [ -n "$1" ] && ! echo "$1" | grep -Eq '^[0-9.]+$'; then
                        log "安全拦截：前端参数 '$1' 包含非法字元，已制止操作"
                        echo '{"result":1,"error":"Invalid format"}'
                        exit 1
                    fi
                }

                # 校验前端数据
                [ "$mode" != "pppoe" ] && validate_ip_format "$arg1" # WAN/LAN IP
                validate_ip_format "$arg2" # Gateway
                validate_ip_format "$arg3" # Netmask

                cleanup_lan_for_wan_modes() {
                    uci delete network.lan.gateway 2>/dev/null
                    uci delete network.lan.dns 2>/dev/null
                    uci set dhcp.lan.ignore='0'
                }
                
                CURRENT_LAN_IP=$(uci -q get network.lan.ipaddr | cut -d/ -f1)

                # 根据 arg5 判断是否埋设防失联定时装置 (0代表不埋，1代表埋设)
                if [ "$mode" = "lan" ] && [ -n "$arg1" ] && [ "$arg1" != "$CURRENT_LAN_IP" ]; then
                    if [ "$arg5" != "0" ]; then
                        log "LAN IP 修改为 $arg1，安放 120 秒防失联回退定时装置"
                        cp /etc/config/network /etc/config/network.netwiz_bak
                        cp /etc/config/dhcp /etc/config/dhcp.netwiz_bak
                        echo "$arg1" > /tmp/netwiz_target_ip
                        echo $(($(date +%s) + 120)) > /tmp/netwiz_rollback_time
                    else
                        log "LAN IP 修改为 $arg1，(直接生效模式) 跳过回退定时装置"
                    fi
                fi

                if [ "$mode" = "wan_dhcp" ]; then
                    cleanup_lan_for_wan_modes
                    uci set network.wan.proto='dhcp'
                    uci commit network
                    uci commit dhcp
                elif [ "$mode" = "wan_static" ]; then
                    cleanup_lan_for_wan_modes
                    uci set network.wan.proto='static'
                    uci set network.wan.ipaddr="$arg1"
                    uci set network.wan.gateway="$arg2"
                    uci set network.wan.netmask="$arg3"
                    uci commit network
                    uci commit dhcp
                elif [ "$mode" = "pppoe" ]; then
                    cleanup_lan_for_wan_modes
                    uci set network.wan.proto='pppoe'
                    uci set network.wan.username="$arg1"
                    uci set network.wan.password="$arg2"
                    uci commit network
                    uci commit dhcp
                elif [ "$mode" = "lan" ]; then
                    uci set network.lan.proto='static'
                    uci set network.lan.ipaddr="$arg1"
                    uci set network.lan.netmask="$arg3"
                    if [ -n "$arg2" ]; then
                        uci set network.lan.gateway="$arg2"
                    else
                        uci delete network.lan.gateway 2>/dev/null
                    fi
                    if [ "$arg4" = "1" ]; then
                        uci set dhcp.lan.ignore='1'
                        [ -n "$arg2" ] && uci set network.lan.dns="$arg2"
                    else
                        uci set dhcp.lan.ignore='0'
                        uci delete network.lan.dns 2>/dev/null
                    fi
                    uci commit network
                    uci commit dhcp
                fi
                
                echo '{"result":0}'
                ( exec >/dev/null 2>&1 </dev/null; sleep 3; /etc/init.d/network restart; /etc/init.d/dnsmasq restart; /etc/init.d/uhttpd restart ) &
                exit 0
                ;;
        esac
        ;;
esac
exit 1
